  "securityDefinitions": {
    "syncsign_auth2": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "x-amazon-apigateway-authtype": "custom",
      "x-amazon-apigateway-authorizer": {
        "type": "request",
        "authorizerUri": "arn:aws:apigateway:us-west-2:lambda:path/2015-03-31/functions/arn:aws:lambda:us-west-2:303785319641:function:syncDisplayAuth/invocations",
        "authorizerResultTtlInSeconds": 300,
        "identitySource": "context.identity.sourceIp, context.path, method.request.header.Authorization"
      }
    }
  },
  "definitions": {
    "ClimateSensor": {
      "type": "object",
      "properties": {
        "humidity": {
          "type": "object",
          "properties": {
            "calibration": {
              "type": "number",
              "description": "Calibrated gap, 0 in default."
            },
            "delayBeforeAlert": {
              "type": "number",
              "description": "Time-delayed (s)"
            },
            "enableAlert": {
              "type": "boolean",
              "description": "If the notification was enable."
            },
            "max": {
              "type": "number",
              "description": "Humidity max threshold for alert, The value of (value * 100)"
            },
            "min": {
              "type": "number",
              "description": "Humidity min threshold for alert, The value of (value * 100)"
            }
          }
        },
        "temperature": {
          "type": "object",
          "properties": {
            "calibration": {
              "type": "number",
              "description": "Calibrated gap, 0 in default"
            },
            "delayBeforeAlert": {
              "type": "number",
              "description": "Time-delayed (s)"
            },
            "enableAlert": {
              "type": "boolean",
              "description": "If the notification was enable"
            },
            "max": {
              "type": "number",
              "description": "Temperature max threshold for alert, The value of (value * 100), unit is (℃)"
            },
            "min": {
              "type": "number",
              "description": "Temperature min threshold for alert, The value of (value * 100), unit is (℃)"
            }
          }
        }
      }
    },
    "DoorSensor": {
      "type": "object",
      "properties": {
        "door_win": {
          "type": "object",
          "properties": {
            "alertWhenStateBecomes": {
              "type": "boolean",
              "description": "If the notification was enable"
            },
            "enableAlert": {
              "type": "boolean",
              "description": "true: notifys when closed, false: notifys when opened"
            }
          }
        }
      }
    },
    "WaterLeakSensor": {
      "type": "object",
