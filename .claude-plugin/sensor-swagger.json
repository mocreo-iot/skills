    "/nodes/{node_id}/samples": {
      "get": {
        "tags": [
          "samples"
        ],
        "operationId": "get_node_samples",
        "description": "Obtain all the samples of this node",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "type": "string",
            "description": "You can get the token of the User by calling the API that  \"/oauth/token\"\nexample: Bearer {{accessToken}}"
          },
          {
            "name": "node_id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "You can get the id of the Node by calling the API that  \"/nodes\""
          },
          {
            "name": "limit",
            "in": "query",
            "type": "number",
            "required": true,
            "description": "The data amount of each query"
          },
          {
            "name": "offset",
            "in": "query",
            "type": "number",
            "description": "offset means this amount of rows were skipped before inquiring:\npageSize * (pageIndex - 1)"
          },
          {
            "name": "beginTime",
            "in": "query",
            "type": "number",
            "description": "Begin time(s)"
          },
          {
            "name": "endTime",
            "in": "query",
            "type": "number",
            "description": "End time(s)"
          }
        ],
        "responses": {
          "200": {
            "description": "The data value is 'o': The returned value when the occupancy sensor is queried. True as Occupied, false as Vacant\ndata is 's': The returned value when the water leak detector/door sensor is queried. True as Leaking/opened, false means Dry /Closed \ndata value is 'tm': When the climate sensor is queried, it represents the temperature (Actual temperature = data/100, unit is (℃))\ndata value is 'hm': When the climate sensor is queried, it represents the humidity (Actual humidity = data/100, unit is %)",
            "schema": {
              "$ref": "#/definitions/ArrayOfRecord"
            }
          }
        },
        "security": [
          {
            "syncsign_auth2": []
          }
        ]
      }
    },
